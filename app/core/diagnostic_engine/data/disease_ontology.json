    "prediabetes": {
      "name": "Pre-diabetes",
      "icd10": "R73.03",
      "category": "metabolic",
      "description": "Impaired glucose regulation preceding diabetes",
      "patterns": {
        "primary": [
          {"marker": "glucose", "condition": "borderline"},
          {"marker": "hba1c", "range": [5.7, 6.4]}
        ],
        "supportive": [
          {"marker": "insulin", "condition": "elevated"},
          {"marker": "triglycerides", "condition": "elevated"}
        ]
      },
      "exclusions": [
        {"marker": "glucose", "condition": ">=", "value": 126}
      ],
      "require_any_primary": true,
      "confidence_factors": {
        "base": 0.45,
        "per_primary_match": 0.25,
        "per_supportive_match": 0.08,
        "temporal_bonus": 0.1,
        "max": 0.90
      },
      "severity_logic": {
        "mild": {"glucose_range": [100, 109]},
        "moderate": {"glucose_range": [110, 119]},
        "advanced": {"glucose_range": [120, 125]}
      },
      "organ_systems": ["metabolic", "endocrine"],
      "related_conditions": ["diabetes_type2", "metabolic_syndrome", "insulin_resistance"],
      "recommended_followup": ["hba1c", "fasting_glucose_repeat", "ogtt", "fasting_insulin"]
    },
