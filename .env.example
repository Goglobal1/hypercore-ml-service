# HyperCore ML Service Environment Configuration
# Copy this file to .env and configure paths for your system

# =============================================================================
# DATASET PATHS - Configure these for local development with full datasets
# =============================================================================

# MIMIC-IV Clinical Data (10GB)
# Download from: https://physionet.org/content/mimiciv/3.1/
MIMIC_PATH=F:/mimic-iv-3.1/mimic-iv-3.1

# ClinVar Genomic Variants (1.1GB full, or use build-time download)
# Download from: https://ftp.ncbi.nlm.nih.gov/pub/clinvar/tab_delimited/
CLINVAR_PATH=F:/DATASETS/GENETICS/ClinVar

# Human Protein Atlas (5.2GB)
# Download from: https://www.proteinatlas.org/about/download
HPA_PATH=F:/DATASETS/PROTEOMICS/Human_Protein_Atlas

# GEO Gene Expression Data (8.3GB)
# Download from: https://www.ncbi.nlm.nih.gov/geo/
GEO_DATA_PATH=F:/DATASETS/GENE_EXPRESSION/GEO_Datasets

# NHANES Population Health (146MB)
# Download from: https://wwwn.cdc.gov/nchs/nhanes/
NHANES_PATH=F:/DATASETS/POPULATION/NHANES

# WHO Global Health Statistics (included in repo, or use external)
# Download from: https://www.who.int/data/gho
WHO_PATH=

# FAERS Adverse Event Reports (2.7GB)
# Download from: https://fis.fda.gov/extensions/FPD-QDE-FAERS/FPD-QDE-FAERS.html
FAERS_PATH=C:/Users/letsa/Downloads

# AACT Clinical Trials Database
# Download from: https://aact.ctti-clinicaltrials.org/
AACT_PATH=

# ChEMBL Drug Database
# Download from: https://www.ebi.ac.uk/chembl/
CHEMBL_PATH=

# =============================================================================
# REDIS CONFIGURATION (for Railway deployment)
# =============================================================================

# Redis URL (Railway will inject REDIS_PRIVATE_URL automatically)
REDIS_URL=redis://localhost:6379
# REDIS_PRIVATE_URL=  # Set by Railway for internal connections

# =============================================================================
# API CONFIGURATION
# =============================================================================

# Server host and port
HOST=0.0.0.0
PORT=8080

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# =============================================================================
# EXTERNAL API KEYS (optional - enables additional features)
# =============================================================================

# PubMed/NCBI E-utilities
NCBI_API_KEY=

# OpenAI (for LLM-enhanced features)
OPENAI_API_KEY=

# =============================================================================
# NOTES
# =============================================================================
#
# For Docker/Railway deployment:
# - HPO data is downloaded at build time (Dockerfile)
# - ClinVar variant_summary.txt.gz is downloaded at build time
# - PharmGKB core files are included in the repo
# - WHO statistics are included in the repo
#
# For local development with full datasets:
# - Configure paths above to your local dataset locations
# - See data/DATASET_INVENTORY.md for complete dataset documentation
#
